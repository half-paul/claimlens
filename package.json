{
  "name": "claimlens",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "tsx scripts/reset-db.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:e2e": "tsx scripts/stop-dev-server.ts && playwright test",
    "test:all": "npm run test:unit && npm run test:e2e",
    "lint": "next lint"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.3.5",
    "lucide-react": "^0.556.0",
    "next": "^16.0.7",
    "pg": "^8.16.3",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
